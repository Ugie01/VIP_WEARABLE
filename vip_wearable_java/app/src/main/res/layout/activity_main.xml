<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/map_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="vertical" />

    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <EditText
            android:id="@+id/search_controller"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="목적지 입력 (텍스트 또는 음성)"
            android:background="@android:color/transparent"
            android:paddingStart="12dp"
            android:imeOptions="actionSearch"
            android:inputType="text" />

        <ImageButton
            android:id="@+id/btn_cancel"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/btn_ble_scan"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/stat_sys_data_bluetooth"
            android:background="@android:color/transparent"
            android:contentDescription="BLE 스캔" />

        <ImageButton
            android:id="@+id/btn_ble_disconnect"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@android:color/transparent"
            android:visibility="gone"
            android:contentDescription="BLE 연결 끊기" />

        <ImageButton
            android:id="@+id/btn_search"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_search"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_manage"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#D9000000"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tv_yaw_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="현재 방향: 0.0°"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="8dp"
            android:background="#F44336"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tv_navigation_msg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="안내를 시작하려면 목적지를 입력하세요."
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>